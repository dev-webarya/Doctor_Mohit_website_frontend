# WhatsApp API (CPass / SobO)
# Copy to .env and fill in your values
# For production, use a backend proxy to keep the API key secure and avoid CORS

VITE_WHATSAPP_API_URL=https://soboapi.cpass.co.in/v3/336425076224393
VITE_WHATSAPP_API_KEY=your-api-key-here

# Optional: prescription template name (default: prescription_ready)
# VITE_WHATSAPP_PRESCRIPTION_TEMPLATE=prescription_ready

# Optional: vaccination reminder template (default: vaccination_reminder)
# Template body params: {{1}}=patientName, {{2}}=vaccineName, {{3}}=dueDate
# VITE_WHATSAPP_VACCINATION_TEMPLATE=vaccination_reminder

